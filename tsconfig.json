{
  "compilerOptions": {
    "allowJs": true,
    "baseUrl": ".",
    "checkJs": false,
    "esModuleInterop": true,
    "jsx": "preserve",
    "noImplicitAny": true,
    "noEmit": true,
    "paths": {
      "@/*": [
        "./assets/*"
      ],
      "@tests/*": [
        "./tests/*"
      ],
      "@wordpress-core/*": [
        "@wordpress/*"
      ],
      "googlesitekit-api": [
        "./assets/js/googlesitekit-api"
      ],
      "googlesitekit-components": [
        "./assets/js/googlesitekit-components"
      ],
      "googlesitekit-data": [
        "./assets/js/googlesitekit-data"
      ],
      "googlesitekit-modules": [
        "./assets/js/googlesitekit-modules"
      ],
      "googlesitekit-notifications": [
        "./assets/js/googlesitekit-notifications"
      ],
      "googlesitekit-widgets": [
        "./assets/js/googlesitekit-widgets"
      ],
      "@wordpress/api-fetch__non-shim": ["./node_modules/@wordpress/api-fetch"],
      "@wordpress/i18n__non-shim": ["./node_modules/@wordpress/i18n"]
    },
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "typeRoots": [
      "./assets/js/types",
      "./node_modules/@types"
    ],
    "strictNullChecks": true,
    "target": "es5"
  },
  "include": [
    "assets",
    "storybook",
    "tests/e2e",
    "tests/js",
    "webpack"
  ],
  "exclude": [
    "coverage",
    "dist",
    "node_modules",
    "php-scoper",
    "third-party",
    "vendor"
  ]
}
