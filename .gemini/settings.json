{
	"context": {
		"fileName": [ "AGENTS.md" ]
	},
	"mcpServers": {
		"github": {
			"trust": false,
			"httpUrl": "https://api.githubcopilot.com/mcp/?toolsets=issues",
			"headers": {
				"Authorization": "Bearer ${GITHUB_TOKEN}"
			},
			"includeTools": [ "issue_read", "list_issues", "search_issues" ]
		}
	}
}
